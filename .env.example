# Copy to .env (repo root) and fill in. .env is gitignored — this repo is
# public, never commit real values.

BUTTERBASE_API_KEY=
# Aura console -> your instance -> Connect -> "Connection URI"
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_INSTANCE_NAME=
ROCKET_RIDE_API_KEY=
# The ONLY account allowed to use the deployed web app. Butterbase signup is
# open to anyone, so the backend admits just one identity and 403s / hides data
# from everyone else. UF_OWNER_EMAIL is for humans; UF_OWNER_USER_ID is what the
# backend actually enforces (deploy_backend.py injects it into the functions AND
# bakes it into owner-only RLS on every table, closing the raw Data API too).
# Get the id: sign up in the web app with UF_OWNER_EMAIL, then it's the
# `user.id` field in the login response. Then rerun deploy_backend.py.
UF_OWNER_EMAIL=
UF_OWNER_USER_ID=

# Optional: end-of-run favorites round-up. When both are set, the scraper
# Telegrams the new post/story links of every poster you've ❤️'d in the web app
# (top story link only per poster). Leave blank to disable the report.
# Bot token from @BotFather; chat id is your channel/chat (e.g. -100…).
TELEGRAM_SEASONS_BOT_TOKEN=
TELEGRAM_SEASONS_CHAT_ID=

# Optional overrides ---------------------------------------------------------
# BUTTERBASE_APP_ID=app_desa1zwpsx43
# UF_CDP_URL=http://localhost:9222
# UF_MAX_POSTS=15
# UF_MAX_STORIES=15
